# Copie para .env e preencha os valores

# ── Segurança ──────────────────────────────────────────────────────────────────
SECRET_KEY=gere-com-openssl-rand-hex-32
JWT_SECRET=gere-com-openssl-rand-hex-32

# ── Banco de dados ─────────────────────────────────────────────────────────────
# Dev (SQLite)
DATABASE_URL=sqlite+aiosqlite:///./database/clube_do_gole.db
# Produção (PostgreSQL)
# DATABASE_URL=postgresql+asyncpg://user:password@host:5432/clube_do_gole

# ── App ────────────────────────────────────────────────────────────────────────
ENV=development
FRONTEND_URL=http://localhost:5173
# Produção: FRONTEND_URL=https://clubedogole.com.br
CORS_ORIGINS=http://localhost:5173
# Produção: CORS_ORIGINS=https://clubedogole.com.br

# ── Admin ──────────────────────────────────────────────────────────────────────
ADMIN_EMAIL_INICIAL=admin@clubedogole.com
ADMIN_SENHA_INICIAL=troque-esta-senha-SEGURA-minimo-12-chars

# ── Mercado Pago ───────────────────────────────────────────────────────────────
# Teste: credenciais começam com TEST-
# Produção: credenciais de produção do painel MP
MP_ACCESS_TOKEN=TEST-seu-access-token
MP_PUBLIC_KEY=TEST-sua-public-key
# URL pública do backend (ngrok em dev, domínio em prod)
BACKEND_PUBLIC_URL=https://xxxx.ngrok-free.app
# Produção: BACKEND_PUBLIC_URL=https://api.clubedogole.com.br

# ── Email (Gmail) ──────────────────────────────────────────────────────────────
# Criar senha de app em: myaccount.google.com/apppasswords
GMAIL_USER=seuemail@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# ── OAuth (opcional) ───────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# O redirect_uri aponta para a ROTA DO FRONTEND, não do backend.
# Dev:  http://localhost:5173/auth/google/callback
# Prod: https://clube-do-gole-frontend.onrender.com/auth/google/callback
GOOGLE_REDIRECT_URI=http://localhost:5173/auth/google/callback
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
# Dev:  http://localhost:5173/auth/facebook/callback
# Prod: https://clube-do-gole-frontend.onrender.com/auth/facebook/callback
FACEBOOK_REDIRECT_URI=http://localhost:5173/auth/facebook/callback
# IMPORTANTE: cadastre EXATAMENTE essas URLs de prod como "Authorized redirect URI"
# no Google Cloud Console e no painel do Facebook, senão o login social falha
# com redirect_uri_mismatch mesmo com as variáveis corretas.
